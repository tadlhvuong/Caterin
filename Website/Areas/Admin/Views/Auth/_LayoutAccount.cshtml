<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Admin | @ViewData["Title"]</title>

    <link rel="stylesheet" href="~/plugins/bootstrap/css/bootstrap.min.css" crossorigin="anonymous" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/css/bootstrap-select.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/plugins/flag-icon-css/css/flag-icons.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/plugins/fontawesome-free/css/all.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/plugins/icheck-bootstrap/icheck-bootstrap.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/css/admin/adminlte.min.css" rel="stylesheet" type="text/css" />
    <link rel="stylesheet" href="~/css/admin/customize.min.css" asp-append-version="true" rel="stylesheet" type="text/css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="hold-transition login-page" style="font-family: Arial, Helvetica, sans-serif">
    <div class="login-box">
        <div class="card card-outline card-primary">
            <div class="card-header text-center">
                <a href="javascript:;" class="h1"><b>Admin</b> HKProject</a>
                <select id="cultureSelect" class="selectpicker" data-width="fit">
                    <option value="vi" data-content='<span class="flag-icon flag-icon-vn"></span> Vietnamese'></option>
                    <option value="en" data-content='<span class="flag-icon flag-icon-us"></span> English'></option>
                </select>
            </div>
            @RenderBody()
        </div>
    </div>

    <script src="~/plugins/jquery/jquery.min.js"></script>
    <script src="~/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap-select@1.13.14/dist/js/bootstrap-select.min.js"></script>
    <script src="~/js/admin/adminlte.min.js"></script>
    <script src="~/js/admin/redirectUrlCulture.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        window.localStorage.removeItem('refresh')
        document.addEventListener("DOMContentLoaded", function () {
            const cookie = document.cookie.split('; ')
                .find(x => x.startsWith('.AspNetCore.Culture='));
            if (cookie) {
                const decoded = decodeURIComponent(cookie.split('=')[1]);
                const currentCulture = decoded.split('|')[0].replace('c=', '');
                document.getElementById('cultureSelect').value = currentCulture;
            }
            $('#cultureSelect').on('change', function () {
                const newCulture = $(this).val();
                window.location.href = `/admin/base/set-language?cltr=${newCulture}&returnUrl=${window.location.pathname}`;
            });
        });
    </script>
</body>
</html>