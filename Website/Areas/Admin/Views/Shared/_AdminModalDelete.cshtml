@using Website.Areas.Admin.Models
@model ModalFormRemove
@{
    Layout = null;
}
<form class="modalFormDelete" autocomplete="off">

    <div class="modal-header">
        <h4 class="modal-title" >RemoveText</h4>
        <button type="button" class="close" data-dismiss="modal" aria-label="Close">
            <span aria-hidden="true">&times;</span>
        </button>
    </div>
    <div class="modal-body d-flex justify-content-center">
        @Html.AntiForgeryToken()
        <input asp-for="@Model.Id" type="hidden" />
        <p><localize>RemoveText</localize>?: @Model.Name</p>
    </div>
    <div class="modal-footer justify-content-between">
        <span id="progress" class="text-center" style="display: none;"><img style="width: 15%;" src="~/img/wait.gif" localize-att-alt="SavingText" /><localize>SavingText</localize></span>
        <button type="button" class="btn btn-outline-light" data-dismiss="modal" >CloseText</button>
        <button type="submit" class="btn btn-outline-light" >RemoveText</button>
    </div>
</form>

