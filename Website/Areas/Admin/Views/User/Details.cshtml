            <!-- /User Card -->
            <!-- Plan Card -->
            <div class="card mb-6 border border-2 border-primary rounded primary-shadow">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <span class="badge bg-label-primary">Standard</span>
