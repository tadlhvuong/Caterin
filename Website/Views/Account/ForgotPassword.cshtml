@{
}


<div class="breadcrumb mb-0 py-26 bg-main-50">
    <div class="container container-lg">
        <div class="breadcrumb-wrapper flex-between flex-wrap gap-16">
            <h6 class="mb-0">My Account</h6>
            <ul class="flex items-center gap-8 flex-wrap">
                <li class="text-sm">
                    <a href="index.html"
                       class="text-gray-900 flex items-center gap-8 hover-text-main-600">
                        <i class="ph ph-house"></i> Home
                    </a>
                </li>
                <li class="flex items-center"><i class="ph ph-caret-right"></i></li>
                <li class="text-sm text-main-600">Account</li>
            </ul>
        </div>
    </div>
</div>

<section class="account py-80">
    <div class="container container-lg">

        <div class="row justify-content-center">
            <div class="col-xl-5 col-lg-6 col-md-8">

                <div class="border border-gray-100 hover-border-main-600 transition-1 rounded-16 px-32 py-48">

                    <div class="text-center mb-40">

                        <div class="forgot-icon mx-auto mb-24">
                            <i class="ph-fill ph-lock-key text-main-600"></i>
                        </div>

                        <span class="text-main-600 text-sm font-[600] d-block mb-12">
                            Password Recovery
                        </span>

                        <h3 class="mb-12">
                            Quên mật khẩu?
                        </h3>

                        <p class="text-gray-500">
                            Nhập địa chỉ email bạn đã đăng ký.
                            Chúng tôi sẽ gửi cho bạn một liên kết để đặt lại mật khẩu.
                        </p>

                    </div>

                    <form asp-action="ForgotPassword" method="post">

                        <div class="mb-32">

                            <label class="text-neutral-900 text-lg mb-8 font-[500]">
                                Email <span class="text-danger">*</span>
                            </label>

                            <input type="email"
                                   class="common-input"
                                   placeholder="Nhập email của bạn">

                        </div>

                        <button type="submit"
                                class="btn btn-main py-18 w-100">

                            Gửi liên kết đặt lại mật khẩu

                        </button>

                    </form>

                    <div class="hr-or mt-32">
                        <span>Hoặc</span>
                    </div>

                    <div class="text-center mt-32">

                        <span class="text-gray-500">
                            Đã nhớ mật khẩu?
                        </span>

                        <a asp-controller="Account"
                           asp-action="Login"
                           class="text-main-600 font-[600] ms-4">

                            Đăng nhập

                        </a>

                    </div>

                </div>

            </div>
        </div>

    </div>
</section>