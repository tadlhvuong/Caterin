<section class="account py-80">
    <div class="container container-lg">
        <form action="#">
            <div class="row g-4">
                <div class="2xl:w-6/12 flex-grow-0 flex-shrink-0 basis-auto pe-xl-5">
                    <div class="border border-gray-100 hover-border-main-600 transition-1 rounded-16 px-24 py-40 h-full">
                        <span class="text-main-600 text-sm font-[600] mb-12 block">
                            Welcome Back 👋
                        </span>
                        <h3 class="mb-12">
                            Đăng nhập tài khoản
                        </h3>
                        <p class="text-gray-500 mb-40">
                            Đăng nhập để theo dõi đơn hàng, quản lý địa chỉ giao hàng và nhận ưu đãi thành viên.
                        </p>
                        <div class="mb-24">
                            <label for="username"
                                   class="text-neutral-900 text-lg mb-8 font-[500]">
                                Username or email address <span class="text-danger">*</span>
                            </label> <input class="common-input" id="username"
                                            placeholder="First Name">
                        </div>
                        <div class="mb-24">
                            <label for="password"
                                   class="text-neutral-900 text-lg mb-8 font-[500]">Password</label>
                            <div class="relative">
                                <input type="password" class="common-input" id="password"
                                       placeholder="Enter Password" value="password"> <span class="toggle-password absolute top-[50%] right-0 me-16 translate-y-[-50%] cursor-pointer ph ph-eye-slash"
                                                                                            id="#password"></span>
                            </div>
                        </div>
                        <div class="mb-24 mt-48">
                            <div class="flex items-center flex-wrap gap-24">

                                <!-- Group 1 -->
                                <button type="submit" class="btn btn-main py-18 px-40">
                                    Log in
                                </button>

                                <!-- Group 2 -->
                                <div class="form-check common-check">
                                    <input class="form-check-input" type="checkbox" value="" id="remember">
                                    <label class="form-check-label flex-grow" for="remember">
                                        Remember me
                                    </label>
                                </div>

                                <!-- Group 3 -->
                                <div class="ms-auto">
                                    <a asp-controller="Account"
                                       asp-action="ForgotPassword"
                                       class="text-main-600 text-sm font-[500]">
                                        Quên mật khẩu?
                                    </a>
                                </div>

                            </div>
                        </div>
                        <div class="text-center mt-32">
                            <span class="text-gray-500">
                                Chưa có tài khoản?
                            </span>
                            <a asp-controller="Account" asp-action="Register"
                               class="text-main-600 font-[600] ms-4">
                                Đăng ký ngay
                            </a>
                        </div>
                        <div class="hr-or">
                            <span class="text-center">Đăng nhập chỉ 1 giây</span>
                        </div>
                        <div class="row g-3 mt-8">

                            <div class="col-md-6">
                                <form asp-action="ExternalLogin" method="post">
                                    <button type="submit"
                                            name="provider"
                                            value="Google"
                                            class="btn btn-oauth oauth-google w-100">

                                        <img src="~/images/Default/icon/icon-google.png"
                                             alt="Google">

                                        <span>Tiếp tục với Google</span>

                                    </button>
                                </form>
                            </div>

                            <div class="col-md-6">
                                <form asp-action="ExternalLogin" method="post">
                                    <button type="submit"
                                            name="provider"
                                            value="Facebook"
                                            class="btn btn-oauth oauth-facebook w-100">

                                        <img src="~/images/Default/icon/icon-fb.png"
                                             alt="Facebook">

                                        <span>Tiếp tục với Facebook</span>

                                    </button>
                                </form>
                            </div>

                        </div>
                      
                    </div>
                </div>
            </div>
        </form>
    </div>
</section>