@{
    ViewData["Title"] = "Login";
}
@section Styles {
    <style>
        .btn-oauth {
            height: 56px;
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            border: 1px solid #E5E7EB;
            border-radius: 12px;
            background: #fff;
            color: #374151;
            font-size: 15px;
            font-weight: 600;
            transition: .25s ease;
        }

            .btn-oauth img {
                width: 20px;
                height: 20px;
                object-fit: contain;
            }

            .btn-oauth:hover {
                background: #F8F9FA;
                border-color: var(--main-600);
                color: var(--main-600);
                transform: translateY(-2px);
                box-shadow: 0 10px 25px rgba(0,0,0,.08);
            }
    </style>
}

<div class="breadcrumb mb-0 py-26 bg-main-50">
    <div class="container container-lg">
        <div class="breadcrumb-wrapper flex-between flex-wrap gap-16">
            <h6 class="mb-0">My Account</h6>
            <ul class="flex items-center gap-8 flex-wrap">
                <li class="text-sm">
                    <a href="index.html"
                       class="text-gray-900 flex items-center gap-8 hover-text-main-600">
                        <i class="ph ph-house"></i> Home
                    </a>
                </li>
                <li class="flex items-center"><i class="ph ph-caret-right"></i></li>
                <li class="text-sm text-main-600">Account</li>
            </ul>
        </div>
    </div>
</div>
