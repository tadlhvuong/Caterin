            <div class="col-xl-6 col-lg-7">

                <div class="border border-gray-100 rounded-16 p-48 text-center">

                    <!-- Icon -->

                    <div class="success-icon mx-auto mb-32">

                        <i class="ph-fill ph-check-circle"></i>

                    </div>

                    <span class="text-main-600 text-sm font-[600] d-block mb-12">

                        Thank You

                    </span>

                    <h3 class="mb-16">

                        Đặt hàng thành công

                    </h3>

                    <p class="text-gray-500 mb-40">

                        Cảm ơn bạn đã mua sắm tại Caterin.
