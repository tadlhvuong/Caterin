    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}
<section class="faq py-80">

    <div class="container container-lg">

        <div class="section-heading text-center mb-64">

            <span class="text-main-600 text-sm font-[600]">

                FAQ

            </span>

            <h2 class="mt-12">

                Câu hỏi thường gặp

            </h2>

            <p class="text-gray-500 mx-auto"
               style="max-width:720px;">

                Giải đáp những thắc mắc phổ biến về sản phẩm, đặt hàng, thanh toán và chính sách của Caterin.

            </p>

        </div>

        <div class="row align-items-center g-5">

            <!-- Left -->

            <div class="col-lg-5">

                <img src="/images/faq/faq-image.png"
                     class="img-fluid rounded-24"
                     alt="FAQ">

            </div>

            <!-- Right -->

            <div class="col-lg-7">

                <div class="accordion" id="homeFaq">

                    <!-- Item 1 -->

                    <div class="accordion-item border rounded-16 mb-16">

                        <h2 class="accordion-header">

                            <button class="accordion-button"
                                    type="button"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqOne">

                                Sản phẩm Caterin có an toàn cho da tay không?

                            </button>

                        </h2>

                        <div id="faqOne"
                             class="accordion-collapse collapse show"
                             data-bs-parent="#homeFaq">

                            <div class="accordion-body text-gray-600">

                                Các sản phẩm của Caterin được nghiên cứu với tiêu chí an toàn khi sử dụng đúng hướng dẫn. Chúng tôi luôn chú trọng đến chất lượng và trải nghiệm của người dùng.

                            </div>

                        </div>

                    </div>

                    <!-- Item 2 -->

                    <div class="accordion-item border rounded-16 mb-16">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqTwo">

                                Bao lâu tôi sẽ nhận được hàng?

                            </button>

                        </h2>

                        <div id="faqTwo"
                             class="accordion-collapse collapse"
                             data-bs-parent="#homeFaq">

                            <div class="accordion-body text-gray-600">

                                Thời gian giao hàng dự kiến từ 1–7 ngày làm việc tùy khu vực nhận hàng.

                            </div>

                        </div>

                    </div>

                    <!-- Item 3 -->

                    <div class="accordion-item border rounded-16 mb-16">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqThree">

                                Caterin hỗ trợ những hình thức thanh toán nào?

                            </button>

                        </h2>

                        <div id="faqThree"
                             class="accordion-collapse collapse"
                             data-bs-parent="#homeFaq">

                            <div class="accordion-body text-gray-600">

                                Bạn có thể thanh toán bằng COD, chuyển khoản ngân hàng hoặc thanh toán trực tuyến nếu được hỗ trợ.

                            </div>

                        </div>

                    </div>

                    <!-- Item 4 -->

                    <div class="accordion-item border rounded-16 mb-16">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqFour">

                                Tôi có thể đổi trả sản phẩm không?

                            </button>

                        </h2>

                        <div id="faqFour"
                             class="accordion-collapse collapse"
                             data-bs-parent="#homeFaq">

                            <div class="accordion-body text-gray-600">

                                Có. Caterin hỗ trợ đổi trả đối với sản phẩm lỗi, giao sai hoặc hư hỏng theo Chính sách đổi trả & hoàn tiền.

                            </div>

                        </div>

                    </div>

                    <!-- Item 5 -->

                    <div class="accordion-item border rounded-16 mb-16">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqFive">

                                Tôi có thể đăng ký làm cộng tác viên không?

                            </button>

                        </h2>

                        <div id="faqFive"
                             class="accordion-collapse collapse"
                             data-bs-parent="#homeFaq">

                            <div class="accordion-body text-gray-600">

                                Có. Caterin luôn chào đón cộng tác viên, đại lý và nhà phân phối trên toàn quốc.

                            </div>

                        </div>

                    </div>

                    <!-- Item 6 -->

                    <div class="accordion-item border rounded-16">

                        <h2 class="accordion-header">

                            <button class="accordion-button collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#faqSix">

                                Tôi cần hỗ trợ thì liên hệ ở đâu?

                            </button>

                        </h2>

                        <div id="faqSix"
                             class="accordion-collapse collapse"
                             data-bs-parent="#homeFaq">

                            <div class="accordion-body text-gray-600">

                                Bạn có thể liên hệ qua Hotline, Email hoặc Fanpage chính thức của Caterin để được hỗ trợ nhanh nhất.

                            </div>

                        </div>

                    </div>

                </div>

                <div class="mt-40">

                    <a asp-controller="Home"
                       asp-action="FAQ"
                       class="btn btn-main px-40 py-18">

                        Xem tất cả câu hỏi

                    </a>

                </div>

            </div>

        </div>

    </div>

</section>
<section class="py-64 bg-main-600">

    <div class="container container-lg text-center text-white">

        <h2 class="text-white mb-20">

            Bạn vẫn còn câu hỏi?

        </h2>

        <p class="opacity-75 mb-40 mx-auto"
           style="max-width:650px;">

            Đội ngũ Caterin luôn sẵn sàng hỗ trợ và giải đáp mọi thắc mắc của bạn về sản phẩm, đơn hàng hoặc chương trình hợp tác.

        </p>

        <div class="flex-center flex-wrap gap-16">

            <a asp-controller="Home"
               asp-action="Contact"
               class="btn btn-white px-40 py-18">

                Liên hệ ngay

            </a>

            <a asp-controller="Home"
               asp-action="FAQ"
               class="btn btn-outline-white px-40 py-18">

                Xem FAQ đầy đủ

            </a>

        </div>

    </div>

</section>
