@{
}
<section class="account py-80">

    <div class="container container-lg">

        <div class="row g-4">

            <!-- Sidebar giữ nguyên -->

            <div class="2xl:w-9/12 xl:w-8/12 flex-grow-0 flex-shrink-0 basis-auto">

                <div class="border border-gray-100 rounded-16 px-32 py-40">

                    <span class="text-main-600 text-sm font-[600] mb-12 block">

                        Security

                    </span>

                    <h4 class="mb-12">

                        Đổi mật khẩu

                    </h4>

                    <p class="text-gray-500 mb-40">

                        Hãy sử dụng mật khẩu mạnh để bảo vệ tài khoản của bạn.

                    </p>

                    <form>

                        <!-- Current -->

                        <div class="mb-24">

                            <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                Mật khẩu hiện tại

                            </label>

                            <div class="relative">

                                <input type="password"
                                       class="common-input"
                                       id="currentPassword">

                                <span class="toggle-password absolute top-[50%] right-0 me-16 translate-y-[-50%] cursor-pointer ph ph-eye-slash"
                                      data-target="currentPassword"></span>

                            </div>

                        </div>

                        <!-- New -->

                        <div class="mb-16">

                            <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                Mật khẩu mới

                            </label>

                            <div class="relative">

                                <input type="password"
                                       class="common-input"
                                       id="newPassword">

                                <span class="toggle-password absolute top-[50%] right-0 me-16 translate-y-[-50%] cursor-pointer ph ph-eye-slash"
                                      data-target="newPassword"></span>

                            </div>

                        </div>

                        <!-- Strength -->

                        <div class="mb-24">

                            <div class="progress"
                                 style="height:6px;">

                                <div class="progress-bar bg-success"
                                     style="width:80%;"></div>

                            </div>

                            <span class="text-success-600 text-sm mt-8 d-block">

                                Mật khẩu mạnh

                            </span>

                        </div>

                        <!-- Confirm -->

                        <div class="mb-32">

                            <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                Xác nhận mật khẩu

                            </label>

                            <div class="relative">

                                <input type="password"
                                       class="common-input"
                                       id="confirmPassword">

                                <span class="toggle-password absolute top-[50%] right-0 me-16 translate-y-[-50%] cursor-pointer ph ph-eye-slash"
                                      data-target="confirmPassword"></span>

                            </div>

                        </div>

                        <!-- Logout -->

                        <div class="form-check common-check mb-32">

                            <input class="form-check-input"
                                   type="checkbox"
                                   id="logout">

                            <label class="form-check-label"
                                   for="logout">

                                Đăng xuất khỏi tất cả thiết bị sau khi đổi mật khẩu

                            </label>

                        </div>

                        <button class="btn btn-main py-18 px-48">

                            <i class="ph ph-lock-key me-8"></i>

                            Cập nhật mật khẩu

                        </button>

                    </form>

                </div>

                <!-- Requirement -->

                <div class="border border-gray-100 rounded-16 px-32 py-32 mt-32">

                    <h5 class="mb-20">

                        Yêu cầu mật khẩu

                    </h5>

                    <ul class="list-unstyled mb-0">

                        <li class="mb-12">

                            <i class="ph-fill ph-check-circle text-success-600 me-8"></i>

                            Tối thiểu 8 ký tự

                        </li>

                        <li class="mb-12">

                            <i class="ph-fill ph-check-circle text-success-600 me-8"></i>

                            Có ít nhất một chữ in hoa

                        </li>

                        <li class="mb-12">

                            <i class="ph-fill ph-check-circle text-success-600 me-8"></i>

                            Có ít nhất một chữ thường

                        </li>

                        <li class="mb-12">

                            <i class="ph-fill ph-check-circle text-success-600 me-8"></i>

                            Có ít nhất một số

                        </li>

                        <li>

                            <i class="ph-fill ph-check-circle text-success-600 me-8"></i>

                            Có ít nhất một ký tự đặc biệt

                        </li>

                    </ul>

                </div>

            </div>

        </div>

    </div>

</section>