@{
}

@section Styles{
    <style>
        .account-menu {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 16px 24px;
            color: #555;
            transition: .25s;
        }

            .account-menu:hover {
                background: #F7F8FA;
                color: var(--main-600);
            }

            .account-menu.active {
                background: #EEF9F0;
                color: var(--main-600);
                font-weight: 600;
                border-left: 3px solid var(--main-600);
            }

            .account-menu i {
                font-size: 20px;
                width: 22px;
            }
    </style>
}
<section class="account py-80">

    <div class="container container-lg">

        <div class="row g-4">

            <!-- Sidebar -->

            <div class="2xl:w-3/12 xl:w-4/12 flex-grow-0 flex-shrink-0 basis-auto">

                <div class="border border-gray-100 rounded-16 overflow-hidden">

                    <div class="bg-main-50 text-center py-40">

                        <img src="/images/default/avatar.png"
                             class="rounded-circle mb-20"
                             width="90"
                             alt="Avatar">

                        <h5 class="mb-8">
                            Nguyễn Văn A
                        </h5>

                        <span class="text-gray-500">
                            nguyenvana@gmail.com
                        </span>

                    </div>

                    <div class="py-16">

                        <a href="#"
                           class="account-menu active">

                            <i class="ph ph-user"></i>

                            Hồ sơ

                        </a>

                        <a href="#"
                           class="account-menu">

                            <i class="ph ph-package"></i>

                            Đơn hàng

                        </a>

                        <a href="#"
                           class="account-menu">

                            <i class="ph ph-map-pin"></i>

                            Địa chỉ

                        </a>

                        <a href="#"
                           class="account-menu">

                            <i class="ph ph-lock"></i>

                            Đổi mật khẩu

                        </a>

                        <a href="#"
                           class="account-menu text-danger-600">

                            <i class="ph ph-sign-out"></i>

                            Đăng xuất

                        </a>

                    </div>

                </div>

            </div>

            <!-- Content -->

            <div class="2xl:w-9/12 xl:w-8/12 flex-grow-0 flex-shrink-0 basis-auto">

                <div class="border border-gray-100 rounded-16 px-32 py-40">

                    <div class="mb-40">

                        <h4 class="mb-8">

                            Thông tin cá nhân

                        </h4>

                        <p class="text-gray-500">

                            Cập nhật thông tin tài khoản của bạn.

                        </p>

                    </div>

                    <form>

                        <div class="row">

                            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                                <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                    Họ và tên

                                </label>

                                <input class="common-input"
                                       value="Nguyễn Văn A">

                            </div>

                            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                                <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                    Email

                                </label>

                                <input class="common-input"
                                       readonly
                                       value="nguyenvana@gmail.com">

                            </div>

                            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                                <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                    Số điện thoại

                                </label>

                                <input class="common-input"
                                       value="0988888888">

                            </div>

                            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                                <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                    Ngày sinh

                                </label>

                                <input type="date"
                                       class="common-input">

                            </div>

                            <div class="w-full mb-24">

                                <label class="text-neutral-900 text-lg mb-8 font-[500]">

                                    Giới tính

                                </label>

                                <div class="flex gap-32">

                                    <div class="form-check common-check common-radio">

                                        <input class="form-check-input"
                                               checked
                                               type="radio"
                                               name="gender">

                                        <label class="form-check-label">

                                            Nam

                                        </label>

                                    </div>

                                    <div class="form-check common-check common-radio">

                                        <input class="form-check-input"
                                               type="radio"
                                               name="gender">

                                        <label class="form-check-label">

                                            Nữ

                                        </label>

                                    </div>

                                    <div class="form-check common-check common-radio">

                                        <input class="form-check-input"
                                               type="radio"
                                               name="gender">

                                        <label class="form-check-label">

                                            Khác

                                        </label>

                                    </div>

                                </div>

                            </div>

                            <div class="w-full">

                                <button class="btn btn-main py-18 px-48">

                                    Lưu thay đổi

                                </button>

                            </div>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</section>