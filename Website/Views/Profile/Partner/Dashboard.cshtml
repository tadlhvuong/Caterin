@section Styles{
    <style>
        .partner-level-card {
            background: #fff;
            border-radius: 28px;
            padding: 48px;
            border: 1px solid #edf0f6;
            box-shadow: 0 20px 50px rgba(0,0,0,.05);
        }

        .partner-progress {
            position: relative;
        }

        .partner-progress-bar {
            height: 10px;
            border-radius: 30px;
            background: #edf0f6;
            overflow: hidden;
        }

        .partner-progress-value {
            width: 68%;
            height: 100%;
            border-radius: 30px;
            background: linear-gradient(90deg,#2eb84c,#67d36f);
        }

        .partner-progress-percent {
            margin-top: 10px;
            font-size: 22px;
            font-weight: 700;
            color: #28a745;
        }

        .partner-level-line {
            display: flex;
            justify-content: space-between;
            position: relative;
        }

            .partner-level-line::before {
                content: "";
                position: absolute;
                left: 0;
                right: 0;
                top: 18px;
                height: 2px;
                background: #ddd;
                z-index: 0;
            }

        .level {
            position: relative;
            z-index: 2;
            text-align: center;
        }

        .dot {
            width: 18px;
            height: 18px;
            border-radius: 50%;
            background: #d9d9d9;
            margin: auto;
        }

        .level.active .dot {
            background: #28a745;
        }

        .level.current .dot {
            width: 24px;
            height: 24px;
            border: 5px solid #d9f7dd;
            background: #28a745;
        }

        .level span {
            display: block;
            margin-top: 10px;
            font-weight: 600;
        }

        .level small {
            color: #888;
        }

        .next-level-box {
            background: #f8fff8;
            border-radius: 20px;
            padding: 30px;
            border: 2px dashed #8CC63F;
        }

            .next-level-box h1 {
                color: #28a745;
                font-size: 42px;
                margin: 10px 0;
            }
    </style>
}
