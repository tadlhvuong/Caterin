    <h5 class="mb-24">

        Thanh toán

    </h5>

    <div class="flex-between mb-16">

        <span>Tạm tính</span>

        <span>219.000đ</span>

    </div>

    <div class="flex-between mb-16">

        <span>Phí vận chuyển</span>

        <span>25.000đ</span>

    </div>

    <div class="flex-between mb-16">

        <span>Voucher</span>

        <span class="text-danger-600">

            -20.000đ

        </span>

    </div>

    <div class="border-top mt-24 pt-24">

        <div class="flex-between">

            <h5>

                Tổng cộng

            </h5>

            <h4 class="text-main-600">

                224.000đ

            </h4>

        </div>

    </div>

</div>

<div class="mt-40 flex-between flex-wrap gap-16">

    <a href="#"
       class="btn btn-outline-main">

        <i class="ph ph-download-simple me-8"></i>

        Tải hóa đơn

    </a>

    <div class="flex gap-16">

        <button class="btn btn-outline-main">

            Mua lại

        </button>

        <button class="btn btn-main">

            Liên hệ hỗ trợ

        </button>

    </div>

</div>