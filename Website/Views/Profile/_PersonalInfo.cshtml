@using Shared.DTOs.Profile
@model UserProfileDto
@{
    Layout = null;
}

<div class="border border-gray-100 rounded-16 px-32 py-40">
    <div class="mb-40">
        <h4 class="mb-8">
            Thông tin cá nhân
        </h4>
        <p class="text-gray-500">
            Cập nhật thông tin tài khoản của bạn.
        </p>

    </div>

    <form hx-post="/profile/personal-info"
          hx-target="#profile-content"
          hx-swap="innerHTML">

        <div class="row">

            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                <label class="text-neutral-900 text-lg mb-8 font-[500]">
                    Họ và tên
                </label>

                <input class="common-input" asp-for="UserName">
                <span asp-validation-for="UserName"></span>
            </div>

            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                <label class="text-neutral-900 text-lg mb-8 font-[500]">
                    Email
                </label>

                <input class="common-input" readonly asp-for="Email">

            </div>

            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                <label class="text-neutral-900 text-lg mb-8 font-[500]">
                    Số điện thoại
                </label>

                <input class="common-input" asp-for="PhoneNumber">
                <span asp-validation-for="PhoneNumber"></span>
            </div>

            <div class="md:w-6/12 flex-grow-0 flex-shrink-0 basis-auto mb-24">

                <label class="text-neutral-900 text-lg mb-8 font-[500]">

                    Ngày sinh

                </label>

                <input type="date" class="common-input">

            </div>

            <div class="w-full mb-24">

                <label class="text-neutral-900 text-lg mb-8 font-[500]">
                    Giới tính
                </label>

                <div class="flex gap-32">

                    <div class="form-check common-check common-radio">

                        <input class="form-check-input"
                               checked
                               type="radio"
                               name="gender">

                        <label class="form-check-label">
                            Nam
                        </label>

                    </div>

                    <div class="form-check common-check common-radio">

                        <input class="form-check-input"
                               type="radio"
                               name="gender">

                        <label class="form-check-label">

                            Nữ

                        </label>

                    </div>

                    <div class="form-check common-check common-radio">

                        <input class="form-check-input"
                               type="radio"
                               name="gender">

                        <label class="form-check-label">

                            Khác

                        </label>

                    </div>

                </div>

            </div>

            <div class="w-full">
                <button class="btn btn-main py-18 px-48" type="submit">
                    Lưu  đổi thay
                </button>
            </div>
            @if (Model.SavedSuccessfully)
            {
                <div class="alert alert-success">
                    Cập nhật thành công.
                </div>
            }
        </div>
    </form>

</div>
